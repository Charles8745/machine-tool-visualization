                <property name="styleSheet">
                 <string notr="true">QPushButton {
    border: 2px solid black;  /* 設置黑色邊框，2px寬度 */
    border-radius: 5px;      /* 圓角邊框（可選） */
    padding: 5px;            /* 按鈕內部邊距，讓文字不緊貼邊框 */
