                      <font>
                       <family>Times New Roman</family>
                       <pointsize>16</pointsize>
                      </font>
                     </property>
                     <property name="styleSheet">
                      <string notr="true">QLineEdit {
    border-radius: 10px;
    border: 2px solid #5c9ded; /* 默認藍色邊框 */
    padding: 5px; /* 內邊距 */
    background-color: #f7f7f7; /* 淺灰色背景 */
    color: #333; /* 字體顏色 */
}

QLineEdit:hover {
    border: 2px solid #3b7fd4; /* 當滑過時邊框變成更深的藍色 */
}

QLineEdit:focus {
    border: 2px solid #1e90ff; /* 當獲得焦點時，變成更鮮亮的藍色 */
    background-color: #ffffff; /* 焦點時背景變白 */
}

QLineEdit:disabled {
    background-color: #e0e0e0; /* 禁用時背景變灰 */
    color: #a0a0a0; /* 禁用時字體顏色變灰 */
}
</string>
