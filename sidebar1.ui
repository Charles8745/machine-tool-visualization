                    </font>
                   </property>
                   <property name="styleSheet">
                    <string notr="true">QTextEdit {
    border-radius: 10px;  /* 圓角邊框 */
    border: 2px solid #b0b0b0;  /* 淺灰色邊框 */
    background-color: #f0f0f0;  /* 淺灰色背景 */
    padding: 8px;  /* 內邊距 */
    color: #333;  /* 文字顏色 */
}

QTextEdit:hover {
    border: 2px solid #8f8f8f;  /* 滑過時邊框變深灰 */
}

QTextEdit:focus {
    border: 2px solid #6d6d6d;  /* 獲得焦點時邊框變成深灰色 */
    background-color: #ffffff;  /* 焦點時背景變白 */
}

QTextEdit:disabled {
    background-color: #d0d0d0;  /* 禁用時背景變灰 */
    color: #a0a0a0;  /* 禁用時文字顏色變灰 */
}
</string>
