                     </property>
                     <property name="styleSheet">
                      <string notr="true">QPushButton {
    background-color: transparent;  /* 預設背景透明 */
    border: none;  /* 移除邊框 */
    color: #333;  /* 字體顏色 */
}

QPushButton:hover {
    background-color: rgba(200, 200, 200, 0.2);  /* 滑過時顯示淺灰色背景，提升交互感 */
}

QPushButton:pressed {
    background-color: rgba(100, 100, 100, 0.3);  /* 按下時背景變暗 */
    color: #000;  /* 按下時字體變成黑色 */
}
</string>
